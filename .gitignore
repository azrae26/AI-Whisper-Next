__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
.venv-pack/
.venv-pack_office/
build/
dist/
*.spec
*.log
# 例外：主程式輸出在 logs/（團隊可納版本庫）；其餘路徑的 *.log 仍忽略。
!logs/
!logs/**/*.log
# 例外：敲麥 / tap 診斷分流 log（可版本庫）。
!tap_test_logs/
!tap_test_logs/**/*.log
# 執行中的最新 log（帶 .current 標記）— 忽略，程式停止後自動改名成一般 .log。
logs/*.current.log
tap_test_logs/*.current.log
config.json
config.json.*
*.pack.bak
